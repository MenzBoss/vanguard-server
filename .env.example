PORT=5000
# Local development example:
# MONGO_URI=mongodb://localhost:27017/fc_vanguard
# Production example (Render/Atlas):
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster-url>/fc_vanguard?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/fc_vanguard
# Optional DB connection tuning (useful for cold starts on hosted environments)
MONGO_CONNECT_RETRIES=4
MONGO_RETRY_DELAY_MS=3000
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
JWT_SECRET=your_super_secret_jwt_key_change_this
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,https://fcvanguard.live,https://www.fcvanguard.live
# Local development example:
# PUBLIC_SERVER_URL=http://localhost:5000
# Production example:
# PUBLIC_SERVER_URL=https://vanguard-server-evr7.onrender.com
PUBLIC_SERVER_URL=http://localhost:5000
ADMIN_EMAIL=admin@fcvanguard.com
ADMIN_PASSWORD=admin123
